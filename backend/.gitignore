.env.*.local

# IDE and editor
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace

# OS
.DS_Store
Thumbs.db
Desktop.ini

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*

# Temporary files
tmp/
temp/
dist/

# Database
*.sqlite
*.db
